INPUT_MODE=dshow
AUTO_DETECT_DEVICES=1
VIDEO_DEVICE=Your Camera Name
AUDIO_DEVICE=Your Microphone Name

# For IP cameras, use this instead:
# INPUT_MODE=rtsp
# RTSP_URL=rtsp://user:pass@camera-ip:554/stream1

REPLAY_MINUTES=3
MAX_BUFFER_MINUTES=5
CHUNK_SECONDS=5
# Wait for the active chunk to finalize before saving a replay.
REPLAY_FINALIZE_WAIT_SECONDS=7
# repair copies video but rebuilds audio timestamps to avoid silent replay tails.
REPLAY_AUDIO_MODE=repair
# Rotate live view and saved clips. Use 0, 90, 180, 270, or any degree value.
CAMERA_ROTATION_DEGREES=0
VIDEO_RESOLUTION=1280x720
FPS=30
VIDEO_CODEC=libx264
# Use VIDEO_CODEC=h264_qsv on Intel Quick Sync. auto selects nv12 for h264_qsv.
VIDEO_PIXEL_FORMAT=auto
AUDIO_CODEC=aac
# Optional override. By default the app uses ./ffmpeg/ffmpeg.exe.
# FFMPEG_PATH=C:\path\to\ffmpeg.exe

LIVE_FPS=5
LIVE_WIDTH=640
LIVE_JPEG_QUALITY=10
DSHOW_RTBUFSIZE=2M
LOW_LATENCY_CAPTURE=1
# For RTSP cameras on a clean LAN, udp can reduce latency; tcp is usually more reliable.
RTSP_TRANSPORT=tcp


# Optional backup copy after the local replay is saved. UNC shares are supported.
# REPLAY_BACKUP_DIR=\\server\share\SigitCamReplays
