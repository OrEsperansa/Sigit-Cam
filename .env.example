INPUT_MODE=dshow
AUTO_DETECT_DEVICES=1
VIDEO_DEVICE=Your Camera Name
AUDIO_DEVICE=Your Microphone Name

# For IP cameras, use this instead:
# INPUT_MODE=rtsp
# RTSP_URL=rtsp://user:pass@camera-ip:554/stream1

REPLAY_MINUTES=3
MAX_BUFFER_MINUTES=5
CHUNK_SECONDS=5
HLS_SEGMENT_SECONDS=1
VIDEO_RESOLUTION=1920x1080
FPS=30
VIDEO_CODEC=libx264
AUDIO_CODEC=aac
# Optional override. By default the app uses ./ffmpeg/ffmpeg.exe.
# FFMPEG_PATH=C:\path\to\ffmpeg.exe

# WebRTC live streaming through bundled MediaMTX.
WEBRTC_HTTP_PORT=8889
WEBRTC_STREAM_PATH=live
RTSP_PUBLISH_URL=rtsp://127.0.0.1:8554/live
